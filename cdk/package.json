{
  "name": "cdk",
  "version": "0.1.0",
  "bin": {
    "cdk": "bin/cdk.js"
  },
  "scripts": {
    "build": "tsc",
    "build:staging": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "cdk deploy --all --require-approval never",
    "deploy:staging": "cd ../frontend && npm run build:staging && cd ../cdk && STAGE=staging cdk deploy --all --require-approval never",
    "deploy:production": "cd ../frontend && npm run build && cd ../cdk && STAGE=production cdk deploy --all --require-approval never"
  },
  "devDependencies": {
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "aws-cdk": "2.1106.1",
    "esbuild": "^0.27.3",
    "jest": "^30",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws-cdk/aws-apigatewayv2-alpha": "^2.114.1-alpha.0",
    "@aws-cdk/aws-apigatewayv2-integrations-alpha": "^2.114.1-alpha.0",
    "aws-cdk-lib": "^2.238.0",
    "constructs": "^10.0.0",
    "dotenv": "^17.3.1"
  }
}
