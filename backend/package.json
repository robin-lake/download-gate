{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "db:create": "tsx src/scripts/createTables.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "node --import tsx --env-file=.env.production src/index.ts",
    "build:staging": "node --import tsx --env-file=.env.staging src/index.ts",
    "build:dev": "node --import tsx --env-file=.env.development src/index.ts",
    "dev": "tsx --watch --env-file=.env.development src/index.ts",
    "dev:otel": "NODE_OPTIONS='--require @aws/aws-distro-opentelemetry-node-autoinstrumentation/register' tsx --watch --env-file=.env.development src/index.ts"
  },
  "keywords": [],
