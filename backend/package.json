    "@clerk/express": "^1.7.76",
    "@codegenie/serverless-express": "^4.17.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.2",
    "@types/supertest": "^6.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0",
